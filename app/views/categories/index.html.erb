<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Categories</h1>
    <%= link_to new_category_path, class: "inline-flex items-center gap-1 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
      </svg>
      New Category
    <% end %>
  </div>

  <% if @categories.any? %>
    <div class="bg-white shadow-sm rounded-xl border border-gray-200 divide-y divide-gray-100">
      <% @categories.each do |category| %>
        <div class="flex items-center justify-between px-5 py-4 hover:bg-gray-50 transition">
          <span class="font-medium text-gray-900"><%= category.name %></span>
          <div class="flex items-center gap-2">
            <span class="text-xs text-gray-500"><%= pluralize(category.tasks.count, "task") %></span>
            <%= link_to edit_category_path(category), class: "text-gray-400 hover:text-gray-600 transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
              </svg>
            <% end %>
            <%= button_to category_path(category), method: :delete, data: { turbo_confirm: "Delete this category? Tasks will become uncategorized." }, class: "text-gray-400 hover:text-red-600 transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
              </svg>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white rounded-xl border border-gray-200 shadow-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
      </svg>
      <h3 class="mt-3 text-sm font-semibold text-gray-900">No categories yet</h3>
      <p class="mt-1 text-sm text-gray-500">Create categories to organize your tasks.</p>
    </div>
  <% end %>

  <div class="pt-4">
    <%= link_to tasks_path, class: "text-sm text-gray-500 hover:text-gray-700" do %>
      &larr; Back to Tasks
    <% end %>
  </div>
</div>
