<%= link_to task_path(task), class: "block text-xs p-1 rounded #{task.completed? ? 'bg-gray-100 text-gray-400 line-through' : 'bg-indigo-100 text-indigo-700 hover:bg-indigo-200'} transition truncate" do %>
  <% if task.priority == "high" && !task.completed? %>
    <span class="inline-block w-1.5 h-1.5 rounded-full bg-red-500 mr-1"></span>
  <% end %>
  <%= task.title %>
<% end %>
