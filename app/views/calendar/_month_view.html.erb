<div class="calendar-grid">
  <div class="grid grid-cols-7 border-b border-gray-100">
    <% %w[Sun Mon Tue Wed Thu Fri Sat].each do |day| %>
      <div class="px-2 py-3 text-center text-xs font-semibold text-gray-500 uppercase tracking-wide">
        <%= day %>
      </div>
    <% end %>
  </div>

  <div class="grid grid-cols-7">
    <% (@start_date..@end_date).each do |date| %>
      <% is_today = date == Date.today %>
      <% is_current_month = date.month == @date.month %>
      <div class="min-h-24 p-2 border-b border-r border-gray-100 <%= 'bg-indigo-50' if is_today %> <%= 'bg-gray-50' unless is_current_month %>">
        <div class="flex items-center justify-between mb-1">
          <span class="text-sm font-medium <%= is_today ? 'text-indigo-600' : (is_current_month ? 'text-gray-900' : 'text-gray-400') %>">
            <%= date.day %>
          </span>
          <% if is_today %>
            <span class="w-2 h-2 rounded-full bg-indigo-600"></span>
          <% end %>
        </div>

        <% if @tasks_by_date[date] %>
          <div class="space-y-1">
            <% @tasks_by_date[date].first(3).each do |task| %>
              <%= render "task_item", task: task, compact: true %>
            <% end %>
            <% if @tasks_by_date[date].size > 3 %>
              <div class="text-xs text-gray-500">+<%= @tasks_by_date[date].size - 3 %> more</div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>
