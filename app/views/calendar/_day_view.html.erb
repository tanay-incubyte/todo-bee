<div class="day-view p-6">
  <% tasks_today = @tasks_by_date[@date] || [] %>

  <% if tasks_today.any? %>
    <div class="space-y-3">
      <% tasks_today.each do |task| %>
        <%= link_to task_path(task), class: "block p-4 rounded-lg border border-gray-200 hover:border-indigo-300 hover:bg-indigo-50 transition" do %>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <% if task.completed? %>
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-green-100 text-green-600">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
              <% else %>
                <span class="inline-flex items-center justify-center w-6 h-6 rounded-full border-2 border-gray-300"></span>
              <% end %>
              <span class="font-medium <%= task.completed? ? 'line-through text-gray-400' : 'text-gray-900' %>">
                <%= task.title %>
              </span>
            </div>

            <div class="flex items-center gap-2">
              <% if task.category.present? %>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">
                  <%= task.category.name %>
                </span>
              <% end %>
              <% if task.priority.present? %>
                <% priority_classes = { "high" => "bg-red-100 text-red-700", "medium" => "bg-yellow-100 text-yellow-700", "low" => "bg-blue-100 text-blue-700" } %>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= priority_classes[task.priority] %>">
                  <%= task.priority.capitalize %>
                </span>
              <% end %>
            </div>
          </div>

          <% if task.description.present? %>
            <p class="mt-2 text-sm text-gray-500 line-clamp-2"><%= task.description %></p>
          <% end %>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-12">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
      </svg>
      <p class="mt-3 text-sm text-gray-500">No tasks due on this day</p>
      <%= link_to new_task_path, class: "mt-4 inline-flex items-center text-sm text-indigo-600 hover:text-indigo-700 font-medium" do %>
        Create a task
      <% end %>
    </div>
  <% end %>
</div>
