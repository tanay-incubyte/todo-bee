<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">Calendar</h1>
    <div class="flex items-center gap-2">
      <%= link_to calendar_path(filter_params.merge(view: "month", date: @date)),
          class: "px-3 py-1.5 text-sm font-medium rounded-lg transition #{@view == 'month' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" do %>
        Month
      <% end %>
      <%= link_to calendar_path(filter_params.merge(view: "week", date: @date)),
          class: "px-3 py-1.5 text-sm font-medium rounded-lg transition #{@view == 'week' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" do %>
        Week
      <% end %>
      <%= link_to calendar_path(filter_params.merge(view: "day", date: @date)),
          class: "px-3 py-1.5 text-sm font-medium rounded-lg transition #{@view == 'day' ? 'bg-indigo-600 text-white' : 'bg-gray-100 text-gray-700 hover:bg-gray-200'}" do %>
        Day
      <% end %>
    </div>
  </div>

  <%= render "shared/filter_bar", base_path: calendar_path(view: @view, date: @date), show_sort: false %>

  <div class="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
      <% case @view %>
      <% when "month" %>
        <%= link_to calendar_path(filter_params.merge(view: @view, date: @date.prev_month)),
            class: "p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition",
            aria: { label: "Previous month" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        <% end %>
        <h2 class="text-lg font-semibold text-gray-900"><%= @date.strftime("%B %Y") %></h2>
        <%= link_to calendar_path(filter_params.merge(view: @view, date: @date.next_month)),
            class: "p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition",
            aria: { label: "Next month" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        <% end %>
      <% when "week" %>
        <%= link_to calendar_path(filter_params.merge(view: @view, date: @date - 7.days)),
            class: "p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition",
            aria: { label: "Previous week" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        <% end %>
        <h2 class="text-lg font-semibold text-gray-900">
          <%= @start_date.strftime("%b %d") %> - <%= @end_date.strftime("%b %d, %Y") %>
        </h2>
        <%= link_to calendar_path(filter_params.merge(view: @view, date: @date + 7.days)),
            class: "p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition",
            aria: { label: "Next week" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        <% end %>
      <% when "day" %>
        <%= link_to calendar_path(filter_params.merge(view: @view, date: @date - 1.day)),
            class: "p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition",
            aria: { label: "Previous day" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
          </svg>
        <% end %>
        <h2 class="text-lg font-semibold text-gray-900"><%= @date.strftime("%A, %B %d, %Y") %></h2>
        <%= link_to calendar_path(filter_params.merge(view: @view, date: @date + 1.day)),
            class: "p-2 text-gray-500 hover:text-gray-700 hover:bg-gray-100 rounded-lg transition",
            aria: { label: "Next day" } do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
          </svg>
        <% end %>
      <% end %>
    </div>

    <% if @view == "month" %>
      <%= render "month_view" %>
    <% elsif @view == "week" %>
      <%= render "week_view" %>
    <% else %>
      <%= render "day_view" %>
    <% end %>
  </div>

  <div class="flex justify-center">
    <%= link_to calendar_path(filter_params.merge(view: @view, date: Date.today)),
        class: "text-sm text-indigo-600 hover:text-indigo-700 font-medium" do %>
      Today
    <% end %>
  </div>
</div>
