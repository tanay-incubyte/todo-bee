<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Todo App" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full">
    <nav class="bg-white shadow-sm border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16 items-center">
          <div class="flex items-center gap-6">
            <%= link_to "Todo App", root_path, class: "text-xl font-bold text-indigo-600 hover:text-indigo-500 transition" %>
            <%= link_to "Calendar", calendar_path, class: "text-sm font-medium #{request.path == calendar_path ? 'text-indigo-600' : 'text-gray-600 hover:text-gray-900'} transition" %>
            <%= link_to "Categories", categories_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900 transition" %>
          </div>
          <div>
            <%= link_to new_task_path, class: "inline-flex items-center gap-1 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
              </svg>
              New Task
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6">
      <% if notice.present? %>
        <div class="mb-6 rounded-lg bg-green-50 border border-green-200 p-4">
          <p class="text-sm text-green-800"><%= notice %></p>
        </div>
      <% end %>

      <% if alert.present? %>
        <div class="mb-6 rounded-lg bg-red-50 border border-red-200 p-4">
          <p class="text-sm text-red-800"><%= alert %></p>
        </div>
      <% end %>

      <%= yield %>
    </main>

    <script>
      // Filter dropdown functions - defined globally once
      window.toggleDropdown = function(button) {
        if (event) event.stopPropagation();
        var menu = button.nextElementSibling;
        var isHidden = menu.classList.contains('hidden');
        
        // Close all dropdowns first
        document.querySelectorAll('.dropdown-menu').forEach(function(m) {
          m.classList.add('hidden');
        });
        
        // Toggle the clicked one
        if (isHidden) {
          menu.classList.remove('hidden');
        }
      };

      window.toggleFilter = function(key, value, isChecked) {
        var url = new URL(window.location.href);
        var currentValue = url.searchParams.get(key) || '';
        var values = currentValue ? currentValue.split(',') : [];
        
        if (isChecked) {
          if (values.indexOf(value) === -1) {
            values.push(value);
          }
        } else {
          values = values.filter(function(v) { return v !== value; });
        }
        
        if (values.length === 0) {
          url.searchParams.delete(key);
        } else {
          url.searchParams.set(key, values.join(','));
        }
        
        window.location.href = url.toString();
      };
      
      window.clearFilter = function(key) {
        var url = new URL(window.location.href);
        url.searchParams.delete(key);
        window.location.href = url.toString();
      };
      
      window.setFilter = function(key, value) {
        var url = new URL(window.location.href);
        if (value === '') {
          url.searchParams.delete(key);
        } else {
          url.searchParams.set(key, value);
        }
        window.location.href = url.toString();
      };

      // Close dropdowns when clicking outside
      document.addEventListener('click', function(e) {
        if (!e.target.closest('.dropdown-menu') && !e.target.closest('button[onclick*="toggleDropdown"]')) {
          document.querySelectorAll('.dropdown-menu').forEach(function(menu) {
            menu.classList.add('hidden');
          });
        }
      });
    </script>
  </body>
</html>
