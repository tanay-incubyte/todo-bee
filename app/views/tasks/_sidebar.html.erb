<aside class="sidebar w-64 flex-shrink-0">
  <div class="bg-white rounded-xl border border-gray-200 shadow-sm p-4 space-y-6">
    <div>
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Status</h3>
      <div class="space-y-1">
        <%= link_to tasks_path(request.query_parameters.except(:status)),
            class: "block px-3 py-2 text-sm rounded-lg transition #{params[:status].blank? ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
          All
        <% end %>
        <%= link_to tasks_path(request.query_parameters.merge(status: "active")),
            class: "block px-3 py-2 text-sm rounded-lg transition #{params[:status] == 'active' ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
          Active
        <% end %>
        <%= link_to tasks_path(request.query_parameters.merge(status: "completed")),
            class: "block px-3 py-2 text-sm rounded-lg transition #{params[:status] == 'completed' ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
          Completed
        <% end %>
      </div>
    </div>

    <div>
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Priority</h3>
      <div class="space-y-1">
        <%= link_to tasks_path(request.query_parameters.except(:priority)),
            class: "block px-3 py-2 text-sm rounded-lg transition #{params[:priority].blank? ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
          All
        <% end %>
        <% %w[high medium low].each do |priority| %>
          <%= link_to tasks_path(request.query_parameters.merge(priority: priority)),
              class: "block px-3 py-2 text-sm rounded-lg transition #{params[:priority] == priority ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
            <%= priority.capitalize %>
          <% end %>
        <% end %>
      </div>
    </div>

    <% if Category.any? %>
      <div>
        <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Category</h3>
        <div class="space-y-1">
          <%= link_to tasks_path(request.query_parameters.except(:category)),
              class: "block px-3 py-2 text-sm rounded-lg transition #{params[:category].blank? ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
            All
          <% end %>
          <% Category.order(:name).each do |category| %>
            <%= link_to tasks_path(request.query_parameters.merge(category: category.id)),
                class: "block px-3 py-2 text-sm rounded-lg transition #{params[:category] == category.id.to_s ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
              <%= category.name %>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div>
      <h3 class="text-xs font-semibold text-gray-500 uppercase tracking-wide mb-3">Sort By</h3>
      <div class="space-y-1">
        <%= link_to tasks_path(request.query_parameters.except(:sort)),
            class: "block px-3 py-2 text-sm rounded-lg transition #{params[:sort].blank? ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
          Newest First
        <% end %>
        <%= link_to tasks_path(request.query_parameters.merge(sort: "due_date")),
            class: "block px-3 py-2 text-sm rounded-lg transition #{params[:sort] == 'due_date' ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
          Due Date
        <% end %>
        <%= link_to tasks_path(request.query_parameters.merge(sort: "priority")),
            class: "block px-3 py-2 text-sm rounded-lg transition #{params[:sort] == 'priority' ? 'bg-indigo-50 text-indigo-700 font-medium' : 'text-gray-700 hover:bg-gray-50'}" do %>
          Priority
        <% end %>
      </div>
    </div>

    <% if params[:priority].present? || params[:category].present? || params[:status].present? || params[:sort].present? %>
      <div class="pt-2 border-t border-gray-100">
        <%= link_to tasks_path, class: "block text-center px-3 py-2 text-sm text-red-600 hover:text-red-700 font-medium" do %>
          Clear All Filters
        <% end %>
      </div>
    <% end %>
  </div>
</aside>
