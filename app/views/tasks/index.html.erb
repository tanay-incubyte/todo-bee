<div class="space-y-4">
  <div class="flex items-center justify-between">
    <h1 class="text-2xl font-bold text-gray-900">My Tasks</h1>
    <p class="text-sm text-gray-500"><%= @tasks.count %> <%= "task".pluralize(@tasks.count) %></p>
  </div>

  <%= form_with url: tasks_path, method: :get, class: "flex items-center gap-3 flex-wrap" do |f| %>
    <%= f.select :priority, [["All Priorities", ""], ["High", "high"], ["Medium", "medium"], ["Low", "low"]], { selected: params[:priority] }, { id: "priority_filter", class: "rounded-lg border-gray-300 text-sm focus:border-indigo-500 focus:ring-indigo-500" } %>
    <%= f.collection_select :category, Category.order(:name), :id, :name, { include_blank: "All Categories", selected: params[:category] }, { id: "category_filter", class: "rounded-lg border-gray-300 text-sm focus:border-indigo-500 focus:ring-indigo-500" } %>
    <%= f.submit "Filter", class: "rounded-lg bg-gray-100 px-3 py-2 text-sm font-medium text-gray-700 hover:bg-gray-200 transition cursor-pointer" %>
    <% if params[:priority].present? || params[:category].present? %>
      <%= link_to "Clear", tasks_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
    <% end %>
  <% end %>

  <% if @tasks.any? %>
    <div class="bg-white shadow-sm rounded-xl border border-gray-200 divide-y divide-gray-100">
      <% @tasks.each do |task| %>
        <div id="task_<%= task.id %>" class="flex items-center px-5 py-4 hover:bg-gray-50 transition group <%= 'task-completed' if task.completed? %>">
          <div class="flex-shrink-0 mr-3">
            <%= button_to toggle_complete_task_path(task), method: :patch, class: "focus:outline-none cursor-pointer", title: task.completed? ? "Mark incomplete" : "Mark complete", form: { class: "inline" } do %>
              <% if task.completed? %>
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full bg-green-100 text-green-600 hover:bg-green-200 transition" title="Mark incomplete">
                  <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" />
                  </svg>
                </span>
              <% else %>
                <span class="inline-flex items-center justify-center w-7 h-7 rounded-full border-2 border-gray-300 hover:border-indigo-400 hover:bg-indigo-50 transition" title="Mark complete">
                </span>
              <% end %>
            <% end %>
          </div>

          <%= link_to task_path(task), class: "flex-1 min-w-0 flex items-center justify-between" do %>
            <span class="<%= task.completed? ? 'line-through text-gray-400' : 'text-gray-900' %> font-medium truncate">
              <%= task.title %>
            </span>
            <div class="flex items-center gap-2 flex-shrink-0 ml-4">
              <% if task.category.present? %>
                <span class="category-badge text-xs font-medium px-2 py-0.5 rounded-full bg-purple-100 text-purple-700">
                  <%= task.category.name %>
                </span>
              <% end %>
              <% if task.priority.present? %>
                <% priority_classes = { "high" => "bg-red-100 text-red-700 priority-high", "medium" => "bg-yellow-100 text-yellow-700 priority-medium", "low" => "bg-blue-100 text-blue-700 priority-low" } %>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= priority_classes[task.priority] %>">
                  <%= task.priority.capitalize %>
                </span>
              <% end %>
              <% if task.due_date.present? %>
                <% overdue = !task.completed? && task.due_date < Date.today %>
                <span class="text-xs font-medium px-2.5 py-1 rounded-full <%= overdue ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600' %>">
                  <%= task.due_date.strftime("%b %d, %Y") %>
                </span>
              <% end %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-gray-400 group-hover:text-gray-600 transition" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
              </svg>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="text-center py-16 bg-white rounded-xl border border-gray-200 shadow-sm">
      <svg xmlns="http://www.w3.org/2000/svg" class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4" />
      </svg>
      <h3 class="mt-3 text-sm font-semibold text-gray-900">No tasks yet</h3>
      <p class="mt-1 text-sm text-gray-500">Get started by creating your first task.</p>
      <div class="mt-6">
        <%= link_to new_task_path, class: "inline-flex items-center gap-1 rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500 transition" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
            <path fill-rule="evenodd" d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z" clip-rule="evenodd" />
          </svg>
          New Task
        <% end %>
      </div>
    </div>
  <% end %>
</div>
