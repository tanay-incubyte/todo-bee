<div class="max-w-2xl">
  <div class="mb-6">
    <%= link_to tasks_path, class: "inline-flex items-center gap-1 text-sm text-gray-500 hover:text-gray-700 transition" do %>
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
        <path fill-rule="evenodd" d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z" clip-rule="evenodd" />
      </svg>
      Back to Tasks
    <% end %>
  </div>

  <div class="bg-white shadow-sm rounded-xl border border-gray-200 p-6">
    <div class="flex items-start justify-between mb-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 <%= 'line-through text-gray-400' if @task.completed? %>">
          <%= @task.title %>
        </h1>
        <div class="mt-2 flex items-center gap-3">
          <span class="inline-flex items-center gap-1 text-xs font-medium px-2.5 py-1 rounded-full <%= @task.completed? ? 'bg-green-100 text-green-700' : 'bg-yellow-100 text-yellow-700' %>">
            <%= @task.completed? ? "Completed" : "Pending" %>
          </span>
          <% if @task.due_date.present? %>
            <% overdue = !@task.completed? && @task.due_date < Date.today %>
            <span class="inline-flex items-center gap-1 text-xs font-medium px-2.5 py-1 rounded-full <%= overdue ? 'bg-red-100 text-red-700' : 'bg-gray-100 text-gray-600' %>">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor">
                <path fill-rule="evenodd" d="M6 2a1 1 0 00-1 1v1H4a2 2 0 00-2 2v10a2 2 0 002 2h12a2 2 0 002-2V6a2 2 0 00-2-2h-1V3a1 1 0 10-2 0v1H7V3a1 1 0 00-1-1zm0 5a1 1 0 000 2h8a1 1 0 100-2H6z" clip-rule="evenodd" />
              </svg>
              <%= @task.due_date.strftime("%B %d, %Y") %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <% if @task.description.present? %>
      <div class="mt-4 pt-4 border-t border-gray-100">
        <h2 class="text-sm font-semibold text-gray-500 uppercase tracking-wide mb-2">Description</h2>
        <p class="text-gray-700 whitespace-pre-wrap"><%= @task.description %></p>
      </div>
    <% end %>

    <div class="mt-6 pt-4 border-t border-gray-100 flex items-center gap-3">
      <%= link_to edit_task_path(@task), class: "inline-flex items-center gap-1 rounded-lg bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path d="M13.586 3.586a2 2 0 112.828 2.828l-.793.793-2.828-2.828.793-.793zM11.379 5.793L3 14.172V17h2.828l8.38-8.379-2.83-2.828z" />
        </svg>
        Edit
      <% end %>
      <%= button_to task_path(@task), method: :delete, data: { turbo_confirm: "Are you sure you want to delete this task?" }, class: "inline-flex items-center gap-1 rounded-lg bg-white px-4 py-2 text-sm font-semibold text-red-600 shadow-sm ring-1 ring-inset ring-red-200 hover:bg-red-50 transition" do %>
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" viewBox="0 0 20 20" fill="currentColor">
          <path fill-rule="evenodd" d="M9 2a1 1 0 00-.894.553L7.382 4H4a1 1 0 000 2v10a2 2 0 002 2h8a2 2 0 002-2V6a1 1 0 100-2h-3.382l-.724-1.447A1 1 0 0011 2H9zM7 8a1 1 0 012 0v6a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v6a1 1 0 102 0V8a1 1 0 00-1-1z" clip-rule="evenodd" />
        </svg>
        Delete
      <% end %>
    </div>
  </div>
</div>
